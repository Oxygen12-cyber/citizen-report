<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.citizenreport" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Citizen Report</name>
    <description>
        Citizens Reporting Solution App
    </description>
    <author email="bincomdevcenter@bincom.net" href="https://bincom.net">
        Bincom Academy
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>
    <plugin name="cordova-plugin-camera" spec="^6.0.0">
        <variable name="ANDROIDX_CORE_VERSION" value="1.6.+" />
    </plugin>
    <plugin name="cordova-plugin-geolocation" spec="^4.1.0">
        <variable name="ANDROIDX_CORE_VERSION" value="1.6.+" />
    </plugin>
    <plugin name="cordova-plugin-local-notification" spec="^0.9.0-beta.2" />
</widget>
